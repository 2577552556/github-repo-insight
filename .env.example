# GitHub Repository Health Check - Environment Variables

# GitHub API token (optional, increases rate limit)
GITHUB_TOKEN=

# DeepSeek API key for AI evaluation (uses rule-based fallback if not set)
DEEPSEEK_API_KEY=

# OpenAI API key for AI evaluation (optional, uses rule-based fallback if not set)
OPENAI_API_KEY=

# API URLs
OPENAI_API_URL=https://api.openai.com/v1
DEEPSEEK_API_URL=https://api.deepseek.com

# Backend URL for frontend (used in Docker)
NEXT_PUBLIC_API_URL=http://localhost:8000