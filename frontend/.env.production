# Production environment variables for frontend
# This file is used when running `npm run build` for production

# Backend API URL
# For Docker deployment, this is set in docker-compose.yml
# For source code deployment, set this to your backend server address
# Examples:
#   - Local development: http://localhost:8000
#   - Docker: http://backend:8000
#   - Server with custom port: http://your-server-ip:8000
NEXT_PUBLIC_API_URL=http://localhost:8000